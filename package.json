    "react-dom": "^19.2.6",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.14",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  },
